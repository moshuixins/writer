{
  "type": "module",
  "version": "5.9.0",
  "packageManager": "pnpm@10.26.2",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:release": "vue-tsc -b && vite build --mode release",
    "build:test": "vue-tsc -b && vite build --mode test",
    "test:permissions": "tsx scripts/permission-regression.ts",
    "serve": "http-server ./dist -o",
    "serve:test": "http-server ./dist-test -o",
    "svgo": "svgo -f src/assets/icons",
    "generate:icons": "tsx ./scripts/generate.icons.ts",
    "lint": "npm-run-all -s lint:tsc lint:eslint lint:stylelint",
    "lint:tsc": "vue-tsc -b",
    "lint:eslint": "eslint . --cache --fix",
    "lint:stylelint": "stylelint \"src/**/*.{css,scss,vue}\" --cache --fix",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "simple-git-hooks",
    "test:visual": "tsx scripts/visual-regression.ts",
    "generate:openapi": "tsx scripts/generate-openapi.ts",
    "lint:eslint:check": "eslint .",
    "lint:stylelint:check": "stylelint \"src/**/*.{css,scss,vue}\"",
    "verify:openapi": "tsx scripts/verify-openapi.ts",
    "guard:pre-push": "pnpm run verify:openapi && pnpm run test:permissions"
  },
  "dependencies": {
    "@tinymce/tinymce-vue": "^6.3.0",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/components": "^14.1.0",
    "@vueuse/core": "^14.1.0",
    "@vueuse/integrations": "^14.1.0",
    "axios": "^1.13.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "defu": "^6.1.4",
    "dompurify": "^3.3.1",
    "element-plus": "^2.13.0",
    "es-toolkit": "^1.43.0",
    "filesize": "^11.0.13",
    "lucide-vue-next": "^0.562.0",
    "markdown-it": "^14.1.1",
    "mitt": "^3.0.1",
    "nprogress": "^0.2.0",
    "path-browserify": "^1.0.1",
    "pinia": "^3.0.4",
    "reka-ui": "^2.7.0",
    "scule": "^1.3.0",
    "tailwind-merge": "^3.4.0",
    "tinymce": "^8.3.2",
    "ua-parser-js": "^2.0.7",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4",
    "vue-sonner": "^2.0.9",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.7.3",
    "@clack/prompts": "^0.11.0",
    "@iconify/json": "^2.2.417",
    "@iconify/vue": "^5.0.0",
    "@stylistic/stylelint-config": "^3.0.1",
    "@types/markdown-it": "^14.1.2",
    "@types/nprogress": "^0.2.3",
    "@types/path-browserify": "^1.0.3",
    "@unocss/eslint-plugin": "^66.5.11",
    "@unocss/preset-legacy-compat": "^66.5.11",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitejs/plugin-vue-jsx": "^5.1.4",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.23",
    "baseline-browser-mapping": "^2.10.0",
    "eslint": "^9.39.2",
    "fs-extra": "^11.3.3",
    "http-server": "^14.1.1",
    "lint-staged": "^16.2.7",
    "npm-run-all2": "^8.0.4",
    "openapi-typescript": "^7.10.1",
    "playwright": "^1.56.1",
    "postcss": "^8.5.6",
    "postcss-nested": "^7.0.2",
    "sass-embedded": "^1.97.1",
    "simple-git-hooks": "^2.13.1",
    "stylelint": "^16.26.1",
    "stylelint-config-recess-order": "^7.4.0",
    "stylelint-config-standard-scss": "^16.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "stylelint-order": "7.0.1",
    "stylelint-scss": "^6.13.0",
    "svgo": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "unocss": "^66.5.11",
    "unocss-preset-animations": "^1.3.0",
    "unplugin-auto-import": "^20.3.0",
    "unplugin-turbo-console": "^2.3.0",
    "unplugin-vue-components": "^30.0.0",
    "vite": "8.0.0-beta.16",
    "vite-plugin-archiver": "^0.2.0",
    "vite-plugin-compression2": "^2.4.0",
    "vite-plugin-env-parse": "^1.0.15",
    "vite-plugin-vue-devtools": "^8.0.7",
    "vue-tsc": "^3.2.1"
  },
  "simple-git-hooks": {
    "pre-commit": "cd frontend && pnpm exec lint-staged",
    "preserveUnused": true,
    "pre-push": "pnpm -C frontend run guard:pre-push"
  }
}
